{
  "annotations": { "list": [] },
  "description": "Métricas de negocio de Amani: citas, pagos Stripe, autenticación y sesiones",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "📅 Citas",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Total Citas Creadas",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_citas_created_total[24h])", "legendFormat": "Hoy" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Citas Canceladas Hoy",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_citas_cancelled_total[24h])", "legendFormat": "Canceladas" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Ritmo de Creación de Citas",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(amani_citas_created_total[1h])", "legendFormat": "Citas/s" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(amani_citas_cancelled_total[1h])", "legendFormat": "Cancelaciones/s" }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 10,
      "title": "💳 Pagos Stripe",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "id": 11,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Pagos Exitosos Hoy",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_payments_stripe_success_total[24h])", "legendFormat": "Exitosos" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "id": 12,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Pagos Fallidos Hoy",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_payments_stripe_failure_total[24h])", "legendFormat": "Fallidos" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Tasa de éxito de pagos Stripe",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(amani_payments_stripe_success_total[5m]) / (rate(amani_payments_stripe_success_total[5m]) + rate(amani_payments_stripe_failure_total[5m]) + 0.001)", "legendFormat": "Tasa éxito" } ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "🔒 Autenticación y Seguridad",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 19 },
      "id": 21,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Logins Exitosos Hoy",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_auth_login_success_total[24h])", "legendFormat": "Exitosos" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 } ] } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 19 },
      "id": 22,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["sum"] } },
      "title": "Logins Fallidos Hoy",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "increase(amani_auth_login_failure_total[24h])", "legendFormat": "Fallidos" } ],
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 23,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Tasa de fallo de login (seguridad)",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(amani_auth_login_failure_total[10m]) / (rate(amani_auth_login_success_total[10m]) + rate(amani_auth_login_failure_total[10m]) + 0.001)", "legendFormat": "Tasa Fallo" } ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "🔌 WebSocket — Sesiones en Tiempo Real",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "max", "last"], "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "title": "Sesiones WebSocket Activas",
      "targets": [ { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "amani_websocket_sessions_active", "legendFormat": "Sesiones Activas" } ],
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["amani", "business", "production"],
  "templating": { "list": [ { "current": {}, "hide": 0, "includeAll": false, "label": "Datasource", "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource" } ] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Amani — Business Metrics",
  "uid": "amani-business",
  "version": 1
}
