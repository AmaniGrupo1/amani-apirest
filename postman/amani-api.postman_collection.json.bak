          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/sesiones/{{idSesion}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idCita\": {{idCita}},\n  \"sessionDate\": \"2026-04-01T11:00:00\",\n  \"durationMinutes\": 60,\n  \"notas\": \"Notas actualizadas\",\n  \"recomendaciones\": \"Continuar con los ejercicios\"\n}" }
          }
        },
        {
          "name": "Sesiones por paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/sesiones/paciente/{{idPaciente}}" }
        },
        {
          "name": "Vista admin - Listar sesiones",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/sesiones/admin" }
        },
        {
          "name": "Vista admin - Obtener sesión",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/sesiones/admin/{{idSesion}}" }
        },
        {
          "name": "Vista psicólogo - Sesiones por psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/sesiones/psicologo/{{idPsicologo}}" }
        },
        {
          "name": "Vista psicólogo - Crear sesión",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/sesiones/psicologo",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idCita\": {{idCita2}},\n  \"sessionDate\": \"2026-04-10T10:00:00\",\n  \"durationMinutes\": 45,\n  \"notas\": \"Sesión de seguimiento\",\n  \"recomendaciones\": \"Mantener rutina\"\n}" }
          }
        }
      ]
    },

    {
      "name": "06 - Ajustes",
      "description": "Configuración de preferencias de usuario.",
      "item": [
        {
          "name": "Crear ajustes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idAjuste', body.idAjuste);",
            "pm.test('Tiene idAjuste', () => pm.expect(body.idAjuste).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/ajustes",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario}},\n  \"idioma\": \"es\",\n  \"notificaciones\": true,\n  \"darkMode\": false,\n  \"timezone\": \"Europe/Madrid\"\n}" }
          }
        },
        {
