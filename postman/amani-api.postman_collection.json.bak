{
  "info": {
    "name": "Amani API REST",
    "description": "Colección completa de pruebas para la API REST de Amani. Ejecutar las carpetas en orden para que las variables de entorno se propaguen correctamente entre requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8080", "type": "string" },
    { "key": "idUsuario",     "value": "", "type": "string" },
    { "key": "idUsuario2",    "value": "", "type": "string" },
    { "key": "idPaciente",    "value": "", "type": "string" },
    { "key": "idPsicologo",   "value": "", "type": "string" },
    { "key": "idCita",        "value": "", "type": "string" },
    { "key": "idCita2",       "value": "", "type": "string" },
    { "key": "idSesion",      "value": "", "type": "string" },
    { "key": "idAjuste",      "value": "", "type": "string" },
    { "key": "idDireccion",   "value": "", "type": "string" },
    { "key": "idHistorial",   "value": "", "type": "string" },
    { "key": "idDiario",      "value": "", "type": "string" },
    { "key": "idProgreso",    "value": "", "type": "string" },
    { "key": "idMensaje",     "value": "", "type": "string" },
    { "key": "idArchivo",     "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "01 - Usuarios",
      "description": "CRUD de usuarios. Crear primero; los IDs se reutilizan en el resto de carpetas.",
      "item": [
        {
          "name": "Crear usuario paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idUsuario', body.idUsuario);",
            "pm.test('Tiene idUsuario', () => pm.expect(body.idUsuario).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/usuarios",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"María\",\n  \"apellido\": \"López\",\n  \"email\": \"maria.lopez@amani.com\",\n  \"password\": \"pass123\",\n  \"rol\": \"paciente\",\n  \"activo\": true\n}" }
          }
        },
        {
          "name": "Crear usuario psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idUsuario2', body.idUsuario);",
            "pm.test('Rol correcto', () => pm.expect(body.rol).to.eql('psicologo'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/usuarios",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"Carlos\",\n  \"apellido\": \"Ruiz\",\n  \"email\": \"carlos.ruiz@amani.com\",\n  \"password\": \"pass123\",\n  \"rol\": \"psicologo\",\n  \"activo\": true\n}" }
          }
        },
        {
          "name": "Listar usuarios",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Respuesta es array', () => pm.expect(pm.response.json()).to.be.an('array'));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/usuarios" }
        },
        {
          "name": "Obtener usuario por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('ID coincide', () => pm.expect(pm.response.json().idUsuario).to.eql(Number(pm.collectionVariables.get('idUsuario'))));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/usuarios/{{idUsuario}}" }
        },
        {
          "name": "Actualizar usuario",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Nombre actualizado', () => pm.expect(pm.response.json().nombre).to.eql('María Actualizada'));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/usuarios/{{idUsuario}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nombre\": \"María Actualizada\",\n  \"apellido\": \"López\",\n  \"email\": \"maria.lopez@amani.com\",\n  \"password\": \"pass123\",\n  \"rol\": \"paciente\",\n  \"activo\": true\n}" }
          }
        },
        {
          "name": "Obtener usuario inexistente (404)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/usuarios/999999" }
        }
      ]
    },

    {
      "name": "02 - Pacientes",
      "description": "Perfil clínico de paciente. Requiere idUsuario creado en la carpeta anterior.",
      "item": [
        {
          "name": "Crear paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idPaciente', body.idPaciente);",
            "pm.test('Tiene idPaciente', () => pm.expect(body.idPaciente).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/pacientes",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario}},\n  \"fechaNacimiento\": \"1995-06-15\",\n  \"genero\": \"femenino\",\n  \"telefono\": \"612345678\"\n}" }
          }
        },
        {
          "name": "Listar pacientes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Array no vacío', () => pm.expect(pm.response.json().length).to.be.greaterThan(0));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/pacientes" }
        },
        {
          "name": "Obtener paciente por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/pacientes/{{idPaciente}}" }
        },
        {
          "name": "Actualizar paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Teléfono actualizado', () => pm.expect(pm.response.json().telefono).to.eql('699000111'));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/pacientes/{{idPaciente}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario}},\n  \"fechaNacimiento\": \"1995-06-15\",\n  \"genero\": \"femenino\",\n  \"telefono\": \"699000111\"\n}" }
          }
        },
        {
          "name": "Vista admin - Listar pacientes",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/pacientes/admin" }
        },
        {
          "name": "Vista admin - Obtener paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/pacientes/admin/{{idPaciente}}" }
        },
        {
          "name": "Vista psicólogo - Obtener paciente",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/pacientes/psicologo/{{idPaciente}}" }
        }
      ]
    },

    {
      "name": "03 - Psicólogos",
      "description": "Perfil profesional de psicólogo. Requiere idUsuario2 creado en la carpeta 01.",
      "item": [
        {
          "name": "Crear psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idPsicologo', body.idPsicologo);",
            "pm.test('Tiene idPsicologo', () => pm.expect(body.idPsicologo).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/psicologos",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario2}},\n  \"especialidad\": \"Ansiedad y estrés\",\n  \"experiencia\": 8,\n  \"descripcion\": \"Especialista en terapia cognitivo-conductual\",\n  \"licencia\": \"PSI-20241101\"\n}" }
          }
        },
        {
          "name": "Listar psicólogos",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/psicologos" }
        },
        {
          "name": "Obtener psicólogo por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/psicologos/{{idPsicologo}}" }
        },
        {
          "name": "Actualizar psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Experiencia actualizada', () => pm.expect(pm.response.json().experiencia).to.eql(10));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/psicologos/{{idPsicologo}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idUsuario\": {{idUsuario2}},\n  \"especialidad\": \"Ansiedad y estrés\",\n  \"experiencia\": 10,\n  \"descripcion\": \"Especialista en terapia cognitivo-conductual\",\n  \"licencia\": \"PSI-20241101\"\n}" }
          }
        },
        {
          "name": "Vista admin - Listar psicólogos",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/psicologos/admin" }
        },
        {
          "name": "Vista admin - Obtener psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/psicologos/admin/{{idPsicologo}}" }
        },
        {
          "name": "Self - Ver propio perfil",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/psicologos/self/{{idPsicologo}}" }
        },
        {
          "name": "Self - Actualizar propio perfil",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/psicologos/self/{{idPsicologo}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"especialidad\": \"Depresión y ansiedad\",\n  \"experiencia\": 10,\n  \"descripcion\": \"Actualización de perfil propio\",\n  \"licencia\": \"PSI-20241101\"\n}" }
          }
        }
      ]
    },

    {
      "name": "04 - Citas",
      "description": "Gestión de citas. Requiere idPaciente e idPsicologo.",
      "item": [
        {
          "name": "Crear cita",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idCita', body.idCita);",
            "pm.test('Tiene idCita', () => pm.expect(body.idCita).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/citas",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idPaciente\": {{idPaciente}},\n  \"idPsicologo\": {{idPsicologo}},\n  \"startDatetime\": \"2026-04-01T10:00:00\",\n  \"durationMinutes\": 60,\n  \"estado\": \"pendiente\",\n  \"motivo\": \"Primera consulta de ansiedad\"\n}" }
          }
        },
        {
          "name": "Listar citas",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas" }
        },
        {
          "name": "Obtener cita por ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas/{{idCita}}" }
        },
        {
          "name": "Actualizar cita",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Estado confirmada', () => pm.expect(pm.response.json().estado).to.eql('confirmada'));"
          ]}}],
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/citas/{{idCita}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idPaciente\": {{idPaciente}},\n  \"idPsicologo\": {{idPsicologo}},\n  \"startDatetime\": \"2026-04-01T11:00:00\",\n  \"durationMinutes\": 50,\n  \"estado\": \"confirmada\",\n  \"motivo\": \"Primera consulta actualizada\"\n}" }
          }
        },
        {
          "name": "Vista admin - Listar citas",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas/admin" }
        },
        {
          "name": "Vista admin - Obtener cita",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas/admin/{{idCita}}" }
        },
        {
          "name": "Vista psicólogo - Listar citas por psicólogo",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas/psicologo/{{idPsicologo}}" }
        },
        {
          "name": "Vista psicólogo - Ver detalle de cita",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": { "method": "GET", "url": "{{baseUrl}}/api/citas/psicologo/detalle/{{idCita}}" }
        },
        {
          "name": "Vista psicólogo - Cambiar estado de cita",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Campo estadoCita existe', () => pm.expect(pm.response.json().estadoCita).to.exist);"
          ]}}],
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/api/citas/psicologo/{{idCita}}/estado",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"estado\": \"completada\"\n}" }
          }
        },
        {
          "name": "Admin - Crear segunda cita (para sesión de psicólogo)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idCita2', body.idCita);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/citas/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idPaciente\": {{idPaciente}},\n  \"idPsicologo\": {{idPsicologo}},\n  \"startDatetime\": \"2026-04-10T10:00:00\",\n  \"durationMinutes\": 45,\n  \"estado\": \"completada\",\n  \"motivo\": \"Segunda cita para test de sesión psicólogo\"\n}" }
          }
        }
      ]
    },

    {
      "name": "05 - Sesiones",
      "description": "Sesiones terapéuticas. Requiere idCita creada en la carpeta anterior.",
      "item": [
        {
          "name": "Crear sesión",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('idSesion', body.idSesion);",
            "pm.test('Tiene idSesion', () => pm.expect(body.idSesion).to.be.a('number'));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/sesiones",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"idCita\": {{idCita}},\n  \"sessionDate\": \"2026-04-01T11:00:00\",\n  \"durationMinutes\": 50,\n  \"notas\": \"Paciente muestra mejoras en manejo del estrés\",\n  \"recomendaciones\": \"Ejercicios de respiración diarios\"\n}" }
          }
        },
        {
          "name": "Listar sesiones",
